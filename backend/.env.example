# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000

# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/metamissmaster?schema=public"

# ── JWT ──────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_different

# ── Frontend URL (CORS + redirects) ──────────────────────
FRONTEND_URL=http://localhost:3000

# ────────────────────────────────────────────────────────
# FAPSHI  (Mobile Money Cameroun — MTN / Orange)
# Dashboard : https://fapshi.com/dashboard
# ────────────────────────────────────────────────────────
FAPSHI_API_USER=your_fapshi_api_user
FAPSHI_API_KEY=your_fapshi_api_key

# ────────────────────────────────────────────────────────
# CINETPAY  (Mobile Money multi-pays africains)
# Dashboard : https://cinetpay.com
# ────────────────────────────────────────────────────────
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id

# ────────────────────────────────────────────────────────
# STRIPE  (Carte internationale)
# Dashboard : https://dashboard.stripe.com
# ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Logs ─────────────────────────────────────────────────
LOG_LEVEL=info
